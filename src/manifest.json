{
  "manifest_version": 3,
  "name": "Mondary NEW TAB",
  "version": "1.0.1",
  "description": "Displays the latest 15 news from mondary.design in a mosaic layout",
  "permissions": [
    "activeTab"
  ],
  "host_permissions": [
    "https://mondary.design/*"
  ],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
