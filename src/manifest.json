{
  "manifest_version": 3,
  "name": "PKnewTab",
  "version": "2.1.0",
  "description": "Displays the latest 15 news from mondary.design in a mosaic layout",
  "permissions": [
    "activeTab"
  ],
  "host_permissions": [
    "https://mondary.design/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "privacy_policy_url": "https://mondary.github.io/Chrome_PKshortcuts/store/privacy-policy-pk-chrome-shortcuts.html"
}
