{
  "manifest_version": 3,
  "name": "PK New Tab",
  "version": "2.1.3",
  "description": "Latest design news from mondary.design. Made by PK-Labs.",
  "short_name": "PK-Labs Tab",
  "host_permissions": [
    "https://mondary.design/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "privacy_policy_url": "https://mondary.github.io/Chrome_PKnewTab/store/privacy-policy-mondary-new-tab.html"
}
